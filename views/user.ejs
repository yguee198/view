<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
    <link rel="stylesheet" href="./output.css">
</head>
<body class="bg-slate-50 min-h-screen p-8">
    <div class="max-w-4xl mx-auto">
        <h2 class="font-bold text-3xl text-slate-800 mb-6">All Users</h2>

        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <table class="w-full">
                <thead class="bg-slate-100">
                    <tr>
                        <th class="text-left p-4 font-semibold text-slate-700">ID</th>
                        <th class="text-left p-4 font-semibold text-slate-700">Username</th>
                        <th class="text-left p-4 font-semibold text-slate-700">Email</th>
                        <th class="text-left p-4 font-semibold text-slate-700">Password</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users && users.length > 0) { %>
                        <% users.forEach(function(user) { %>
                            <tr class="border-t border-slate-100">
                                <td class="p-4 text-slate-600"><%= user.id %></td>
                                <td class="p-4 text-slate-800 font-medium"><%= user.username %></td>
                                <td class="p-4 text-slate-600"><%= user.email %></td>
                                <td class="p-4 text-slate-600"><%= user.password %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="p-8 text-center text-slate-500">No users found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="mt-6">
            <a href="/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors">
                Back to Signup
            </a>
        </div>
    </div>
</body>
</html>