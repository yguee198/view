<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
    <link rel="stylesheet" href="./output.css">
    <% if (typeof success !== 'undefined' && success) { %>
        <meta http-equiv="refresh" content="3;url=/signin">
    <% } %>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl p-10 w-full max-w-md mx-4">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-6">
                <%= error %>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl mb-6">
                <%= success %> <br>
                <span class="text-sm">Redirecting to sign in...</span>
            </div>
        <% } %>
        <h2 class="font-bold text-3xl text-slate-800 mb-2">Create an account</h2>
        <p class="text-slate-500 mb-8">Enter your details to get started.</p>

        <form action="/users/create" method="post" class="space-y-5">
            <div>
                <label for="username" class="block font-semibold text-sm text-slate-700 mb-1">Username</label>
                <input type="text" name="username" id="username" placeholder="johndoe" 
                    class="w-full bg-slate-100 p-3 rounded-xl border border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all">
            </div>

            <div>
                <label for="email" class="block font-semibold text-sm text-slate-700 mb-1">Email</label>
                <input type="email" name="email" id="email" placeholder="name@company.com" 
                    class="w-full bg-slate-100 p-3 rounded-xl border border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all">
            </div>

            <div>
                <label for="password" class="block font-semibold text-sm text-slate-700 mb-1">Password</label>
                <input type="password" name="password" id="password" placeholder="•••••••" 
                    class="w-full bg-slate-100 p-3 rounded-xl border border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all">
            </div>

            <div class="pt-2">
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl p-3 shadow-lg shadow-blue-200 transition-colors">
                    Sign up
                </button>
            </div>
        </form>
    </div>
</body>
</html>